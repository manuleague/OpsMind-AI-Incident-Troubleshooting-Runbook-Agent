# ============================================================
# OpsMind AI - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# --- Retrieval Mode ---
# Options: "local" (use local markdown runbooks) or "foundry" (use Foundry IQ).
# Use "local" for testing without Azure. Use "foundry" for the real hackathon demo.
OPSMIND_RETRIEVAL_MODE=local

# --- Local Knowledge Base ---
# Path to the local runbooks directory, relative to the project root.
OPSMIND_KB_PATH=knowledge_base/runbooks

# Number of top results to retrieve.
OPSMIND_TOP_K=4

# ============================================================
# FOUNDRY IQ CONFIGURATION
# Required only when OPSMIND_RETRIEVAL_MODE=foundry
# ============================================================

# --- Azure AI Foundry Project ---
# Connection string from your Azure AI Foundry project.
# Find it in: Azure AI Foundry portal > Your Project > Overview > Project connection string.
AZURE_AI_PROJECT_CONNECTION_STRING=

# --- Authentication Mode ---
# Options: "credential" (DefaultAzureCredential, recommended) or "apikey" (API key auth).
FOUNDRY_IQ_AUTH_MODE=credential

# --- Knowledge Base ---
# The ID of your Foundry IQ knowledge base.
# Create it in: Azure AI Foundry portal > Agents > Knowledge Bases.
FOUNDRY_IQ_KNOWLEDGE_BASE_ID=

# --- REST Fallback ---
# Base endpoint URL for the Foundry IQ REST API.
# Format: https://<your-search-resource>.search.windows.net
FOUNDRY_IQ_ENDPOINT=

# API key for REST fallback authentication.
FOUNDRY_IQ_API_KEY=

# API version. Do not change unless Microsoft updates the preview version.
FOUNDRY_IQ_API_VERSION=2025-11-01-preview
